# --- Auth.js (SPEC §2) ---
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# URL pubblico canonico dell'istanza (solo origin, es. https://tuohost.esempio.it
# — niente path in coda). SENZA questa variabile, next-auth deduce l'host dagli
# header X-Forwarded-Host/X-Forwarded-Proto della richiesta: dietro un reverse
# proxy che non li inoltra in modo perfettamente coerente su OGNI richiesta
# (osservato con Tailscale Serve), il redirect_uri OAuth calcolato all'avvio
# del login può differire da quello usato nello scambio finale del codice con
# Google, che allora rifiuta con "invalid_request" / "doesn't comply with
# Google's OAuth 2.0 policy". Impostare AUTH_URL bypassa del tutto gli header
# ed elimina il problema alla radice — fortemente raccomandato per qualunque
# istanza dietro reverse proxy, non solo se si usa Google OAuth.
AUTH_URL=

# Google OAuth — crea le credenziali su https://console.cloud.google.com
# (guida passo-passo: docs/security-privacy.md § Google OAuth). Redirect URI
# da registrare: https://<host>/api/auth/callback/google — Google richiede
# HTTPS per qualunque host diverso da localhost, un dominio LAN in HTTP puro
# (tipo http://wealthwatcher.home.nf) non è accettato come redirect URI.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Dev login (Credentials provider, passwordless). Se 'true' abilita un form
# email che accetta chiunque sia in allowlist SENZA prova di possesso (niente
# password/OTP) — comodo in locale, ma non un controllo di accesso robusto.
# Lasciare 'false' (o non impostata) su qualunque istanza raggiungibile da
# chi non è pienamente fidato, VPN inclusa: in quel caso l'unico login resta
# Google OAuth, che dimostra il possesso dell'account.
AUTH_DEV_LOGIN=false

# Bootstrap allowlist: questa email viene inserita come admin al primo avvio.
SEED_ADMIN_EMAIL=

# --- Content-Security-Policy (src/proxy.ts) ---
# Se 'true', aggiunge 'upgrade-insecure-requests' alla CSP: il browser
# richiederà OGNI risorsa (JS/CSS/font) via HTTPS sullo stesso host.
# Impostalo SOLO se l'istanza è davvero raggiunta via HTTPS end-to-end —
# altrimenti (es. HTTP puro dietro VPN) rompe l'intera pagina
# (ERR_SSL_UNRECOGNIZED_NAME_ALERT su ogni asset, perché non c'è un
# listener TLS su quell'host).
FORCE_HTTPS_UPGRADE=false

# --- Cifratura dati a riposo (src/lib/crypto.ts) ---
# Chiave dedicata per i segreti cifrati nel DB (chiavi OpenAI/Enable Banking,
# session_id bancari). Se non impostata, si usa AUTH_SECRET come fallback —
# ma allora ruotare AUTH_SECRET rende irrecuperabili quei segreti. Impostare
# una chiave dedicata permette di ruotare AUTH_SECRET (sessioni) senza
# toccare la cifratura dei dati.
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY=

# Chiave per cifrare i file di backup del DB (scripts/backup.ts). Stesso
# fallback su AUTH_SECRET se non impostata — vedi docs/backup.md.
BACKUP_ENCRYPTION_KEY=

# --- Database ---
# Default: ./data/chat.db (in Docker: /data/chat.db)
DATABASE_PATH=

# Dove scrivere i backup (default: <dir del db>/backups)
BACKUP_DIR=

# --- Prezzi di mercato (M2) ---
# Alpha Vantage API key (opzionale — free tier 25 req/giorno).
# Se non impostata, il provider Alpha Vantage è disabilitato.
# Ottieni su: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# CoinMarketCap API key (opzionale — fallback crypto dopo CoinGecko).
# Se non impostata, il provider CMC è disabilitato (CoinGecko rimane primario).
# Ottieni su: https://coinmarketcap.com/api/
COINMARKETCAP_KEY=

# Tempo di vita della cache prezzi in minuti (default 30).
PRICE_TTL_MINUTES=30

# Stima valore veicoli via scraping AutoScout24 (nessuna API ufficiale disponibile —
# vedi src/lib/prices/autoscout24.ts). Nessuna chiave richiesta.
# Tempo di vita della stima in minuti prima di rifetchare (default 1440 = giornaliero).
VEHICLE_ESTIMATE_TTL_MINUTES=1440
# Kill-switch: metti a 0 per disattivare lo scraping se AutoScout24 cambia
# struttura/blocca le richieste, senza dover fare un deploy di codice.
AUTOSCOUT_ENABLED=1

# --- Open Banking (Enable Banking — import automatico saldi/movimenti) ---
# Il piano gratuito di Enable Banking è per-account: ogni utente registra la
# propria app su https://enablebanking.com e incolla app_id + chiave privata
# nelle impostazioni dell'app (Impostazioni → Open Banking), NON qui — le
# credenziali sono per-utente, cifrate nel DB, non un'unica var globale.
#
# Questa è l'unica var globale rimasta: l'URL di QUESTO server che riceve il
# redirect dopo il consenso PSU. È lo stesso per tutti gli utenti (è il
# nostro endpoint, non la loro app) — ognuno lo whitelista nel proprio
# Control Panel Enable Banking.
# Es: https://<host>/api/banking/callback
ENABLE_BANKING_REDIRECT_URL=
